<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Receptionist Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
</head>
<body class="bg-light">
    <form asp-controller="Account"
          asp-action="Logout"
          method="post"
          class="d-flex justify-content-end mb-3">

        @Html.AntiForgeryToken()

        <button type="submit"
                class="btn btn-outline-danger">
            <i class="bi bi-box-arrow-right me-1"></i>
            Logout
        </button>

    </form>

        <!-- Header -->
        <div class="mb-4 text-center">
            <h2 class="fw-bold">Receptionist Dashboard</h2>
            <p class="text-muted">Hotel Management System</p>
        </div>

        <!-- Cards -->
        <div class="row g-4 justify-content-center">

            <!-- Customer -->
            <div class="col-md-3">
                <a href="/customers" class="text-decoration-none">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-person-lines-fill fs-1 text-primary"></i>
                            <h5 class="mt-3 fw-semibold text-dark">Customer</h5>
                            <p class="text-muted small">
                                Add, view and search customers
                            </p>
                            <span class="btn btn-outline-primary btn-sm mt-2">
                                Open
                            </span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Rooms -->
            <div class="col-md-3">
                <a href="/rooms" class="text-decoration-none">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-door-closed-fill fs-1 text-success"></i>
                            <h5 class="mt-3 fw-semibold text-dark">Rooms</h5>
                            <p class="text-muted small">
                                View room availability and pricing
                            </p>
                            <span class="btn btn-outline-success btn-sm mt-2">
                                Open
                            </span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Stay -->
            <div class="col-md-3">
                <a href="/stays" class="text-decoration-none">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-journal-check fs-1 text-info"></i>
                            <h5 class="mt-3 fw-semibold text-dark">Stay</h5>
                            <p class="text-muted small">
                                Check-in, checkout and manage stays
                            </p>
                            <span class="btn btn-outline-info btn-sm mt-2">
                                Open
                            </span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Drop & Pick -->
            <div class="col-md-3">
                <a href="/cabservice" class="text-decoration-none">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-car-front-fill fs-1 text-warning"></i>
                            <h5 class="mt-3 fw-semibold text-dark">Drop & Pick</h5>
                            <p class="text-muted small">
                                Manage customer transport requests
                            </p>
                            <span class="btn btn-outline-warning btn-sm mt-2">
                                Open
                            </span>
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </div>

</body>
</html>