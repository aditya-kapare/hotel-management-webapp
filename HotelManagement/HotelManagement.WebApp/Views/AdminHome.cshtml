<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Admin Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
</head>

<body class="bg-light">

    <div class="container py-5">

        <!-- Header -->
        <div class="mb-4 text-center">
            <h2 class="fw-bold">Admin Dashboard</h2>
            <p class="text-muted">Hotel Management System</p>
        </div>

        <!-- Cards -->
        <div class="row g-4 justify-content-center">

            <!-- Employee -->
            <div class="col-md-4">
                <a href="/admin/employees/home" class="text-decoration-none">
                    <div class="card shadow-sm border-0 h-100 hover-card">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-people-fill fs-1 text-primary"></i>
                            <h5 class="mt-3 fw-semibold text-dark">Employee</h5>
                            <p class="text-muted small">
                                Manage hotel staff, salaries and details
                            </p>
                            <span class="btn btn-outline-primary btn-sm mt-2">
                                Open
                            </span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Room -->
            <div class="col-md-4">
                <a href="/admin/rooms" class="text-decoration-none">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-door-closed-fill fs-1 text-success"></i>
                            <h5 class="mt-3 fw-semibold text-dark">Room</h5>
                            <p class="text-muted small">
                                Manage rooms, availability and pricing
                            </p>
                            <span class="btn btn-outline-success btn-sm mt-2">
                                Open
                            </span>
                        </div>
                    </div>
                </a>
            </div>

            <!-- Cab Driver -->
            <div class="col-md-4">
                <a href="/admin/cabdrivers" class="text-decoration-none">
                    <div class="card shadow-sm border-0 h-100">
                        <div class="card-body text-center p-4">
                            <i class="bi bi-car-front-fill fs-1 text-warning"></i>
                            <h5 class="mt-3 fw-semibold text-dark">Cab Driver</h5>
                            <p class="text-muted small">
                                Manage cab drivers and assignments
                            </p>
                            <span class="btn btn-outline-warning btn-sm mt-2">
                                Open
                            </span>
                        </div>
                    </div>
                </a>
            </div>

        </div>
    </div>

</body>
</html>
