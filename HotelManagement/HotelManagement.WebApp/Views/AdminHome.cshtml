<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>Admin Dashboard</title>

    <!-- Bootstrap -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <style>
        .dashboard-card {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
            cursor: pointer;
        }

            .dashboard-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            }
        /* Dashboard page container */
        .dashboard-wrapper {
            max-width: 1200px;
            margin: auto;
        }

        /* Card polish */
        .dashboard-card {
            border-radius: 14px;
            transition: transform .25s ease, box-shadow .25s ease;
        }

            .dashboard-card:hover {
                transform: translateY(-8px);
                box-shadow: 0 12px 28px rgba(0,0,0,0.18);
            }

        /* Icon background */
        .dashboard-icon {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            margin-bottom: 12px;
        }

        /* Icon color themes */
        .icon-primary {
            background: #e7f1ff;
            color: #0d6efd;
        }

        .icon-success {
            background: #eafaf1;
            color: #198754;
        }

        .icon-warning {
            background: #fff4e5;
            color: #fd7e14;
        }

        .icon-info {
            background: #e8f6fd;
            color: #0dcaf0;
        }

        /* Header spacing */
        .dashboard-header {
            margin-bottom: 2rem;
        }

        /* Logout button polish */
        .logout-btn {
            border-radius: 20px;
        }
    </style>
</head>

<body class="bg-light">
    <form asp-controller="Account"
          asp-action="Logout"
          method="post"
          class="d-flex justify-content-end mb-3">

        @Html.AntiForgeryToken()

    </form>

        <!-- Header -->
        <div class="mb-4 text-center">
            <h2 class="fw-bold">Admin Dashboard</h2>
            <p class="text-muted">Hotel Management System</p>
        </div>

        <!-- Cards -->
        <div class="row g-4 justify-content-center">

            <!-- Employee -->
            <div class="col-md-4">
                <a href="/admin/employees" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 dashboard-card">
                        <div class="card-body text-center p-4">
                        <div class="dashboard-icon icon-primary">
                            <i class="bi bi-people-fill fs-2"></i>
                        </div>
                            <h5 class="mt-3 fw-semibold text-dark">Employee</h5>
                            <p class="text-muted small">
                                Manage hotel staff, salaries and details
                            </p>
                          
                        </div>
                    </div>
                </a>
            </div>

            <!-- Room -->
            <div class="col-md-4">
                <a href="/admin/rooms" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 dashboard-card">
                        <div class="card-body text-center p-4">
                        <div class="dashboard-icon icon-success">
                            <i class="bi bi-door-closed-fill fs-2"></i>
                        </div>

                            <h5 class="mt-3 fw-semibold text-dark">Room</h5>
                            <p class="text-muted small">
                                Manage rooms, availability and pricing
                            </p>
                        
                        </div>
                    </div>
                </a>
            </div>

            <!-- Cab Driver -->
            <div class="col-md-4">
                <a href="/admin/cabdrivers" class="text-decoration-none">
                <div class="card shadow-sm border-0 h-100 dashboard-card">
                        <div class="card-body text-center p-4">
                        <div class="dashboard-icon icon-warning">
                            <i class="bi bi-car-front-fill fs-2"></i>
                        </div>
                            <h5 class="mt-3 fw-semibold text-dark">Cab Driver</h5>
                            <p class="text-muted small">
                                Manage cab drivers and assignments
                            </p>
                           
                        </div>
                    </div>
                </a>
            </div>

        </div>
    

</body>
</html>
