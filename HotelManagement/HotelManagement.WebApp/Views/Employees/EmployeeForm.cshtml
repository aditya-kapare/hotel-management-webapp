@model dynamic
@{
    var m = Model;

    bool isEdit = ViewBag.AadharNo != null;
    var aadharValue = m?.AadharNo ?? "";
}

<div class="card shadow-sm border-0">
    <div class="card-body p-4">

        <!-- BASIC INFORMATION -->
        <h6 class="fw-bold text-primary mb-3">Basic Information</h6>

        <div class="row g-3 mb-4">

            <!-- Aadhaar -->
            <div class="col-md-3">
                <label class="form-label">Aadhaar</label>

                @if (!isEdit)
                {
                    <input class="form-control"
                           name="AadharNo"
                           type="text"
                           value="@aadharValue"
                           inputmode="numeric"
                           pattern="[0-9]{12}"
                           minlength="12"
                           maxlength="12"
                           required
                           title="Aadhaar must be exactly 12 digits" />
                }
                else
                {
                    <input class="form-control"
                           value="@ViewBag.AadharNo"
                           readonly />
                }
            </div>

            <!-- Name -->
            <div class="col-md-3">
                <label class="form-label">Name</label>
                <input class="form-control"
                       name="Name"
                       value="@(m?.Name ?? "")"
                       required />
            </div>

            <!-- Age -->
            <div class="col-md-3">
                <label class="form-label">Age</label>
                <input type="number"
                       class="form-control"
                       name="Age"
                       value="@(m?.Age ?? "")"
                       min="18"
                       required />
            </div>

            <!-- Gender -->
            <div class="col-md-3">
                <label class="form-label">Gender</label>
                <select name="Gender"
                        class="form-select"
                        required>
                    <option value="">-- Select Gender --</option>
                    <option value="Male" selected="@(m?.Gender == "Male")">Male</option>
                    <option value="Female" selected="@(m?.Gender == "Female")">Female</option>
                    <option value="Other" selected="@(m?.Gender == "Other")">Other</option>
                </select>
            </div>
        </div>

        <!-- POSITION -->
        <div class="row g-3 mb-4">
            <div class="col-md-4">
                <label class="form-label">Position</label>
                <select name="EmployeePosition"
                        class="form-select"
                        required>
                    <option value="">-- Select Position --</option>
                    <option value="Admin"
                            selected="@(m?.EmployeePosition == "Admin")">
                        Admin
                    </option>
                    <option value="Receptionist"
                            selected="@(m?.EmployeePosition == "Receptionist")">
                        Receptionist
                    </option>
                </select>
            </div>
        </div>

        <hr />

        <!-- EMPLOYMENT DETAILS -->
        <h6 class="fw-bold text-success mb-3">Employment Details</h6>

        <div class="row g-3">

            <!-- Salary -->
            <div class="col-md-4">
                <label class="form-label">Salary</label>
                <input type="number"
                       class="form-control"
                       name="Salary"
                       min="0"
                       value="@(m?.Salary ?? "")" />
            </div>

            <!-- Mobile -->
            <div class="col-md-4">
                <label class="form-label">Mobile</label>
                <input type="text"
                       class="form-control"
                       name="MobileNo"
                       value="@(m?.MobileNo ?? "")"
                       inputmode="numeric"
                       pattern="[0-9]{10}"
                       minlength="10"
                       maxlength="10"
                       required
                       title="Mobile number must be exactly 10 digits" />
            </div>

            <!-- Email -->
            <div class="col-md-4">
                <label class="form-label">Email</label>
                <input type="email"
                       class="form-control"
                       name="EmailId"
                       value="@(m?.EmailId ?? "")"
                       required />
            </div>
        </div>

        <!-- PASSWORD (ONLY FOR CREATE) -->
        @if (!isEdit)
        {
            <hr />

            <h6 class="fw-bold text-warning mb-3">Login Credentials</h6>

            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Password</label>

                    <input type="password"
                           name="Password"
                           class="form-control"
                           required
                           minlength="8"
                           oninvalid="this.setCustomValidity('Password format is invalid. Please follow password rules.')"
                           oninput="this.setCustomValidity('')" />

                    <small class="text-muted">
                        Password rules are enforced on submit.
                    </small>
                </div>
            </div>
        }

    </div>
</div>