@model HotelManagement.WebApp.Application.Dtos.Employee.EmployeeDetailsDto

<div class="container mt-5">
    <div class="card border-danger shadow">
        <div class="card-body text-center">

            <h4 class="text-danger fw-bold">Delete Employee</h4>

            <p class="mt-3">
                Are you sure you want to permanently delete
                <strong>@Model.Name</strong>?
            </p>

            <form method="post"
                  asp-action="DeleteConfirmed"
                  asp-route-aadharNo="@Model.AadharNo">

                <div class="mt-4 d-flex justify-content-center gap-3">

                    <button type="submit" class="btn btn-danger">
                        Yes, Delete
                    </button>

                    <!-- ✅ Context-aware Cancel -->
                    @{
                        var returnUrl = TempData["ReturnUrl"]?.ToString();
                    }

                    @if (!string.IsNullOrEmpty(returnUrl))
                    {
                        <a href="@returnUrl" class="btn btn-secondary">
                            Cancel
                        </a>
                    }
                    else
                    {
                        <a asp-action="Index" class="btn btn-secondary">
                            Cancel
                        </a>
                    }

                </div>
            </form>

        </div>
    </div>
</div>