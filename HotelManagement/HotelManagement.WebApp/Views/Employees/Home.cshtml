<link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-5">

    <!-- Header with Back Button -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h4 class="fw-bold mb-0">Employee Management</h4>

        <a href="/admin/home" class="btn btn-outline-secondary btn-sm">
            ← Back
        </a>
    </div>

    <!-- Cards Row -->
    <div class="row g-4">

        <!-- Employee Directory -->
        <div class="col-md-6">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="fw-semibold">Employee Directory</h5>
                    <p class="text-muted">
                        View all employees
                    </p>

                    <a href="/admin/employees" class="btn btn-primary">
                        Open Directory
                    </a>
                </div>
            </div>
        </div>

        <!-- View by Aadhaar -->
        <div class="col-md-6">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="fw-semibold">View by Aadhaar</h5>
                    <p class="text-muted">
                        Search employee by Aadhaar number
                    </p>

                    <a href="/admin/employees/ViewById" class="btn btn-primary">
                        Search
                    </a>
                </div>
            </div>
        </div>


        <div class="col-md-4">
            <div class="card shadow h-100">
                <div class="card-body">
                    <h5 class="fw-semibold">Add Employee</h5>
                    <p class="text-muted">Register a new employee</p>

                    <a href="/admin/employees/create" class="btn btn-primary">
                        Add Employee
                    </a>
                </div>
            </div>
        </div>



    </div>
</div>