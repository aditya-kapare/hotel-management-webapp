@model IReadOnlyList<HotelManagement.WebApp.Application.Dtos.Employee.EmployeeSummaryDto>

<link href="~/lib/bootstrap/css/bootstrap.min.css" rel="stylesheet" />

<div class="container mt-4">

    @* ✅ DELETE SUCCESS MESSAGE *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">Employee Directory</h4>

        <a href="/admin/employees/create" class="btn btn-primary btn-sm">
            + Add Employee
        </a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Aadhaar</th>
                <th>Name</th>
                <th>Position</th>
                <th>Mobile</th>
                <th class="text-center">Action</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.AadharNo</td>
                    <td>@emp.Name</td>
                    <td>@emp.EmployeePosition</td>
                    <td>@emp.MobileNo</td>
                    <td class="text-center">
                        <a href="/admin/employees/details?aadharNo=@emp.AadharNo"
                           class="btn btn-success btn-sm">
                            View
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a href="/admin/home" class="btn btn-secondary mt-3">
        ← Back
    </a>

</div>
