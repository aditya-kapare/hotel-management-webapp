@model IReadOnlyList<HotelManagement.WebApp.Application.Dtos.Employee.EmployeeSummaryDto>

<div class="container mt-4">

    <h4 class="fw-bold mb-3">Employee Directory</h4>

    <form asp-action="Index"
          asp-controller="Employees"
          method="get"
          class="row g-2 mb-3 align-items-end">

    

        <!-- SEARCH -->
        <div class="col-md-3">
            <label class="form-label">Search</label>
            <input name="search"
                   class="form-control"
                   placeholder="Name or Mobile or Aadhar" />
        </div>

        <!-- SEARCH BUTTON ✅ -->
        <div class="col-md-1">
            <button type="submit"
                    name="actionType"
                    value="Search"
                    class="btn btn-secondary w-100">
                Search
            </button>
        </div>

        <!-- RESET -->
        <div class="col-md-1">
            <a asp-action="Index"
               class="btn btn-danger w-100">
                Reset
            </a>
        </div>

    </form>

    <!-- ✅ EMPLOYEE TABLE (ALWAYS VISIBLE) -->
    <table class="table table-bordered table-hover">
        <thead class="table-dark">
            <tr>
                <th>Aadhaar</th>
                <th>Name</th>
                <th>Position</th>
                <th>Mobile</th>
                <th>Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.AadharNo</td>
                    <td>@emp.Name</td>
                    <td>@emp.EmployeePosition</td>
                    <td>@emp.MobileNo</td>
                    <td>
                        <a asp-action="Details"
                           asp-route-aadharNo="@emp.AadharNo"
                           class="btn btn-sm btn-success">View</a>

                        <a asp-action="Edit"
                           asp-route-aadharNo="@emp.AadharNo"
                           class="btn btn-sm btn-info ms-1">Edit</a>

                        <a asp-action="Delete"
                           asp-route-aadharNo="@emp.AadharNo"
                           class="btn btn-sm btn-danger ms-1">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>