@{
    ViewData["Title"] = "Add Employee";
}

<div class="container mt-5">

    <div class="d-flex justify-content-between align-items-start mb-4">
        <div>
            <h3 class="fw-bold">Add Employee</h3>
            <small class="text-muted">Register a new employee</small>
        </div>

        <a href="/admin/employees" class="btn btn-dark">
            ← Back
        </a>
    </div>

  
    <form method="post" action="/admin/employees/create">

        @await Component.InvokeAsync("EmployeeForm", Model)

        <div class="card-footer bg-light pt-3 pb-4">
            <div class="d-flex justify-content-end gap-2">
                <button type="submit" class="btn btn-primary px-4">
                    Save Employee
                </button>
            </div>
        </div>
    </form>
</div>