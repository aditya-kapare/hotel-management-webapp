@model IReadOnlyList<HotelManagement.WebApp.Application.Dtos.Stays.StayDto>

<style>
    .table.compact-table th,
    .table.compact-table td {
        padding: 0.4rem 0.5rem;
        vertical-align: middle;
        white-space: nowrap;
    }

    .actions-cell .btn {
        margin-bottom: 2px;
    }
</style>

<div class="container-fluid mt-4 px-4">

    <!-- HEADER WITH BACK BUTTON -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold mb-0">Active Stays</h4>

        <a href="/stays"
           class="btn btn-dark">
            Back
        </a>
    </div>

    <!-- SEARCH FORM -->
    <form method="get" class="row g-2 mb-3">

        <div class="col-md-4">
            <input name="customer"
                   value="@ViewBag.Customer"
                   class="form-control"
                   placeholder="Search Customer Name / ID" />
        </div>

        <div class="col-md-2">
            <input name="roomNo"
                   value="@ViewBag.RoomNo"
                   class="form-control"
                   placeholder="Room No" />
        </div>

        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100">
                Search
            </button>
        </div>

        <div class="col-md-2">
            <a asp-action="Index" class="btn btn-outline-danger w-100">
                Reset
            </a>
        </div>

    </form>

    <!-- TABLE -->
    <table class="table table-bordered table-hover align-middle compact-table">
        <thead class="table-dark">
            <tr>
                <th>Stay Id</th>
                <th>Customer ID</th>
                <th class="col-customer-name">Customer Name</th>
                <th>Mobile No</th>
                <th>Room No</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var stay in Model)
            {
                <tr>
                    <td>@stay.StayId</td>
                    <td>@stay.CustomerIdentityId</td>
                    <td class="col-customer-name">@stay.Customer?.Name</td>
                    <td>@stay.Customer?.MobileNo</td>
                    <td>@stay.RoomNo</td>
                    <td class="text-center actions-cell">
                        <a asp-action="ViewDetails"
                           asp-route-stayId="@stay.StayId"
                           class="btn btn-sm btn-secondary">
                            View Details
                        </a>

                        <a asp-action="Edit"
                           asp-route-stayId="@stay.StayId"
                           class="btn btn-sm btn-info ms-1">
                            Edit
                        </a>

                        <a asp-action="CheckOut"
                           asp-route-stayId="@stay.StayId"
                           class="btn btn-sm btn-danger ms-1">
                            Check‑Out
                        </a>

                        <a asp-controller="CabService"
                           asp-action="Create"
                           asp-route-stayId="@stay.StayId"
                           asp-route-identityId="@stay.CustomerIdentityId"
                           class="btn btn-sm btn-warning ms-1">
                            Book Cab
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

</div>