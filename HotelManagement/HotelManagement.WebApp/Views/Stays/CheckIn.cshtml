@model HotelManagement.WebApp.ViewModels.Stays.CheckInStayViewModel

<h3>Check In Guest</h3>

<!-- =========================
     CUSTOMER DETAILS (READONLY)
     ========================= -->
<div class="mb-3">
    <label>Customer Name</label>
    <input class="form-control" value="@Model.CustomerName" readonly />
</div>

<div class="mb-3">
    <label>Mobile No</label>
    <input class="form-control" value="@Model.MobileNo" readonly />
</div>

<!-- =========================
     STEP 1: LOAD AVAILABLE ROOMS
     ========================= -->
<form method="post" asp-action="LoadRooms" asp-controller="Stays">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="CustomerIdentityId" />
    <input type="hidden" asp-for="CustomerName" />
    <input type="hidden" asp-for="MobileNo" />
    <input type="hidden" asp-for="CheckInAt" />

    <div class="mb-3">
        <label>Room Type</label>
        <select asp-for="RoomType"
                asp-items="Model.RoomTypes"
                class="form-control"
                required>
            <option value="">-- Select Room Type --</option>
        </select>
    </div>

    <div class="mb-3">
        <label>AC Option</label>
        <select asp-for="AcOption"
                asp-items="Model.AcOptions"
                class="form-control"
                required>
            <option value="">-- Select AC Option --</option>
        </select>
    </div>

    <button type="submit" class="btn btn-secondary">
        Load Available Rooms
    </button>
</form>
<hr />

<!-- =========================
     STEP 2: CONFIRM CHECK-IN
     ========================= -->
@if (Model.AvailableRooms != null && Model.AvailableRooms.Any())
{
    <form method="post" asp-action="CheckIn" asp-controller="Stays">
        @Html.AntiForgeryToken()

        <input type="hidden" asp-for="CustomerIdentityId" />
        <input type="hidden" asp-for="RoomType" />
        <input type="hidden" asp-for="AcOption" />
        <input type="hidden" asp-for="CheckInAt" />

        <div class="mb-3">
            <label>Room Number</label>
            <select asp-for="RoomNo"
                    asp-items="Model.AvailableRooms"
                    class="form-control"
                    required>
                <option value="">-- Select Room --</option>
            </select>
            <span asp-validation-for="RoomNo" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label>Deposit Paid</label>
            <input asp-for="DepositPaid"
                   class="form-control"
                   type="number"
                   min="0"
                   step="0.01"
                   required />
        </div>

        <button type="submit" class="btn btn-primary">
            Confirm Check-In
        </button>
    </form>
}