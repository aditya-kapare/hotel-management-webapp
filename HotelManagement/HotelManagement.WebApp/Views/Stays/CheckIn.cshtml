@model HotelManagement.WebApp.ViewModels.Stays.CheckInStayViewModel

<h3>Check In Guest</h3>


<form method="post"
      action="/stays/checkin/@Model.CustomerIdentityId">
    @Html.AntiForgeryToken()

    <input type="hidden" asp-for="ActionType" value="Submit" />

    <input type="hidden" asp-for="CustomerIdentityId" />

    <div class="mb-3">
        <label>Customer Name</label>
        <input class="form-control" value="@Model.CustomerName" readonly />
    </div>

    <div class="mb-3">
        <label>Mobile No</label>
        <input class="form-control" value="@Model.MobileNo" readonly />
    </div>

    @* <div>
        <input type="hidden" asp-for="CheckInAt" value="@DateTime.Now" />
    </div> *@

    <div class="mb-3">
        <label>Check-In Date & Time</label>
        <input asp-for="CheckInAt"
               type="datetime-local"
               class="form-control" />
        @Html.ValidationMessageFor(m => m.CheckInAt, "", new { style = "color:red" })
    </div>

    <!-- Room Type -->
    <div class="mb-3">
        <label>Room Type</label>
        <select id="RoomType" name="RoomType" class="form-control">
            <option value="">-- Select Room Type --</option>
            @foreach (var rt in Model.RoomTypes)
            {
                <option value="@rt.Value">@rt.Text</option>
            }
        </select>
    </div>

    <!-- AC Option -->
    <div class="mb-3">
        <label>AC Option</label>
        <select id="AcOption" name="AcOption" class="form-control">
            <option value="">-- Select AC Option --</option>
            @foreach (var ac in Model.AcOptions)
            {
                <option value="@ac.Value">@ac.Text</option>
            }
        </select>
    </div>

    <!-- Room Number -->
    <div class="mb-3">
        <label>Room Number</label>
        <select id="RoomNo" name="RoomNo" class="form-control">
            <option value="">-- Select Room --</option>
        </select>
    </div>

    <!-- Price -->
    <div class="mb-3">
        <label>Price</label>
        <input id="Price" class="form-control" readonly />
    </div>

    <!-- Deposit -->
    <div class="mb-3">
        <label>Deposit Paid</label>
        <input asp-for="DepositPaid" class="form-control" />
        @Html.ValidationMessageFor(m => m.DepositPaid, "", new { style = "color:red" })
    </div>

    <button type="submit" class="btn btn-primary">
        Confirm Check-In
    </button>
    <a href="/customers" class="btn btn-secondary ms-2">
        Cancel
    </a>
</form>

<script>
    const roomType = document.getElementById("RoomType");
    const acOption = document.getElementById("AcOption");
    const roomNo = document.getElementById("RoomNo");
    const priceBox = document.getElementById("Price");

    function loadRooms() {
        if (!roomType.value || !acOption.value) return;

        fetch(`/Stays/GetAvailableRooms?roomType=${roomType.value}&acOption=${acOption.value}`)
            .then(res => res.json())
            .then(data => {
                roomNo.innerHTML = '<option value="">-- Select Room --</option>';
                priceBox.value = "";

                data.forEach(r => {
                    const opt = document.createElement("option");
                    opt.value = r.roomNo;
                    opt.text = r.roomNo;
                    roomNo.appendChild(opt);
                });
            });
    }

    function loadPrice() {
        if (!roomNo.value) return;

        fetch(`/Stays/GetRoomPrice?roomNo=${roomNo.value}`)
            .then(res => res.json())
            .then(data => {
                priceBox.value = data.price;
            });
    }

    roomType.addEventListener("change", loadRooms);
    acOption.addEventListener("change", loadRooms);
    roomNo.addEventListener("change", loadPrice);
</script>