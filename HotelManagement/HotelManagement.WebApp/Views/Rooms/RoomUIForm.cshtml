@model dynamic
@using HotelManagement.WebApp.Domain.Enums

@{
    var m = Model;
}

<div class="row g-3">

    @* ✅ Room Number – only for CREATE *@
    @if (m != null && m.GetType().GetProperty("RoomNo") != null)
    {
        <div class="col-md-6">
            <label class="form-label">Room Number</label>
            <input type="number"
                   name="RoomNo"
                   value="@m.RoomNo"
                   class="form-control"
                   required />
        </div>
    }

    <!-- ✅ Room Type -->
    <div class="col-md-6">
        <label class="form-label">Room Type</label>
        <select name="RoomType" class="form-select" required>
            @foreach (RoomType type in Enum.GetValues(typeof(RoomType)))
            {
                <option value="@((int)type)"
                        selected="@(m != null && m.RoomType == (int)type)">
                    @type
                </option>
            }
        </select>
    </div>

    <!-- ✅ AC Option -->
    <div class="col-md-6">
        <label class="form-label">AC Option</label>
        <select name="AcOption" class="form-select" required>
            @foreach (AcOption ac in Enum.GetValues(typeof(AcOption)))
            {
                <option value="@((int)ac)"
                        selected="@(m != null && m.AcOption == (int)ac)">
                    @ac
                </option>
            }
        </select>
    </div>

    @* ✅ Availability Status – EDIT only *@
    @if (m != null && m.GetType().GetProperty("AvailabilityStatus") != null)
    {
        <div class="col-md-6">
            <label class="form-label">Availability Status</label>
            <select name="AvailabilityStatus" class="form-select" required>
                @foreach (AvailabilityStatus s in Enum.GetValues(typeof(AvailabilityStatus)))
                {
                    <option value="@((int)s)"
                            selected="@(m.AvailabilityStatus == (int)s)">
                        @s
                    </option>
                }
            </select>
        </div>
    }

    @* ✅ Clean Status – EDIT only *@
    @if (m != null && m.GetType().GetProperty("CleanStatus") != null)
    {
        <div class="col-md-6">
            <label class="form-label">Clean Status</label>
            <select name="CleanStatus" class="form-select" required>
                @foreach (CleanStatus c in Enum.GetValues(typeof(CleanStatus)))
                {
                    <option value="@((int)c)"
                            selected="@(m.CleanStatus == (int)c)">
                        @c
                    </option>
                }
            </select>
        </div>
    }

    <!-- ✅ Price -->
    <div class="col-md-6">
        <label class="form-label">Price</label>
        <input type="number"
               step="0.01"
               name="Price"
               value="@(m != null ? m.Price : 0)"
               class="form-control"
               required
               min="0" />
    </div>

</div>