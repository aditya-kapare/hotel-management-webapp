@model dynamic
@using HotelManagement.WebApp.Domain.Enums

@{
    var m = Model;
}

<div class="row g-3">

    @* Room Number only if model + property exist *@
    @if (m != null && m.GetType().GetProperty("RoomNo") != null)
    {
        <div class="col-md-6">
            <label class="form-label">Room Number</label>
            <input type="number"
                   name="RoomNo"
                   value="@m.RoomNo"
                   class="form-control" />
        </div>
    }

    <div class="col-md-6">
        <label class="form-label">Room Type</label>
        <select name="RoomType" class="form-select">
            @foreach (RoomType type in Enum.GetValues(typeof(RoomType)))
            {
                <option value="@type"
                        selected="@(m != null && m.RoomType == type)">
                    @type
                </option>
            }
        </select>
    </div>

    <div class="col-md-6">
        <label class="form-label">AC Option</label>
        <select name="AcOption" class="form-select">
            @foreach (AcOption ac in Enum.GetValues(typeof(AcOption)))
            {
                <option value="@ac"
                        selected="@(m != null && m.AcOption == ac)">
                    @ac
                </option>
            }
        </select>
    </div>

    <div class="col-md-6">
        <label class="form-label">Availability Status</label>
        <select name="AvailabilityStatus" class="form-select">
            @foreach (AvailabilityStatus s in Enum.GetValues(typeof(AvailabilityStatus)))
            {
                <option value="@s"
                        selected="@(m != null && m.AvailabilityStatus == s)">
                    @s
                </option>
            }
        </select>
    </div>

    <div class="col-md-6">
        <label class="form-label">Clean Status</label>
        <select name="CleanStatus" class="form-select">
            @foreach (CleanStatus c in Enum.GetValues(typeof(CleanStatus)))
            {
                <option value="@c"
                        selected="@(m != null && m.CleanStatus == c)">
                    @c
                </option>
            }
        </select>
    </div>

    <div class="col-md-6">
        <label class="form-label">Price</label>
        <input type="number"
               step="0.01"
               name="Price"
               value="@(m != null ? m.Price : 0)"
               class="form-control" />
    </div>

</div>