@model IReadOnlyList<HotelManagement.WebApp.Application.Dtos.Room.RoomDto>
@using HotelManagement.WebApp.Domain.Enums

@{
    ViewData["Title"] = "Rooms";
}



@functions {
    string FormatRoomType(string value)
    {
        return System.Text.RegularExpressions.Regex
            .Replace(value, "(\\B[A-Z])", " $1");
    }
}
@functions {

    string FormatEnumText(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
            return value;

        if (value.Equals("AC", StringComparison.OrdinalIgnoreCase))
            return "AC";

        if (value.Equals("NonAC", StringComparison.OrdinalIgnoreCase) ||
            value.Equals("NonAc", StringComparison.OrdinalIgnoreCase))
            return "Non AC";

        return System.Text.RegularExpressions.Regex
            .Replace(value, "(?<=[a-z])([A-Z])", " $1");
    }
}




<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Rooms</h3>
        <div>

            @if (ViewBag.IsReadOnly)
            {
                <!-- Receptionist -->
                <a href="/reception/home" class="btn btn-dark mt-3">
                    ← Back
                </a>
            }
            else
            {
                <!-- Admin -->
                <a href="/admin/home" class="btn btn-secondary mt-3">
                    ← Back
                </a>
            }

        @if (!ViewBag.IsReadOnly)
        {
            <a asp-action="Create" class="btn btn-primary mt-3 ">Add Room</a>
        }
        </div>
      

    </div>

    <form method="get" class="row g-2 mb-3 align-items-end">

        <!-- Room Type (SMALLER NOW) -->
        <div class="col-md-2">
            <select name="type" class="form-select">
                <option value="">All Room Types</option>
                @foreach (var rt in ViewBag.RoomTypes)
                {
                    <option value="@rt" selected="@(ViewBag.SelectedType == rt)">
                        @FormatEnumText(rt)
                    </option>
                }
            </select>
        </div>

        <!-- AC Option -->
        <div class="col-md-2">
            <select name="acOption" class="form-select">
                <option value="">All AC</option>
                @foreach (var ac in ViewBag.AcOptions)
                {
                    <option value="@ac" selected="@(ViewBag.SelectedAc == ac)">
                        @FormatEnumText(ac)
                    </option>
                }
            </select>
        </div>

        <!-- Clean Status -->
        <div class="col-md-2">
            <select name="cleanStatus" class="form-select">
                <option value="">Cleanliness</option>
                @foreach (var cs in ViewBag.CleanStatuses)
                {
                    <option value="@cs" selected="@(ViewBag.SelectedClean == cs)">
                        @cs
                    </option>
                }
            </select>
        </div>

        <!-- Availability -->
        <div class="col-md-2">
            <select name="availabilityStatus" class="form-select">
                <option value="">Availability</option>
                @foreach (var av in ViewBag.AvailabilityStatuses)
                {
                    <option value="@av" selected="@(ViewBag.SelectedAvailability == av)">
                        @av
                    </option>
                }
            </select>
        </div>

        <!-- Filter Button -->
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100">
                Filter
            </button>
        </div>

        <!-- Reset Button -->
        <div class="col-md-2">
            @if (ViewBag.IsReadOnly)
            {
                <a href="/rooms" class="btn btn-outline-danger w-100">
                    Reset
                </a>
            }
            else
            {
                <a href="/admin/rooms" class="btn btn-outline-danger w-100">
                    Reset
                </a>
            }
        </div>

    </form>
   
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Room No</th>
                <th>Type</th>
                <th>AC</th>
                <th>Availability Status</th>
                <th>Cleanliness status</th>
                <th class="text-end">Price</th>
                @if (!ViewBag.IsReadOnly)
                {
                    <th class="text-center">Actions</th>
                }
                `
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.RoomNo</td>
                    <td>@FormatEnumText(r.RoomType.ToString())</td>
                    <td>@FormatEnumText(r.AcOption.ToString())</td>
                    <td>
                        <span class="badge @(r.AvailabilityStatus.ToString() == "Available"
                                                      ? "bg-success" : "bg-danger")">
                        @r.AvailabilityStatus
                    </span>
                </td>
                <td>@r.CleanStatus</td>
                <td class="text-end">₹ @r.Price</td>

                @if (!ViewBag.IsReadOnly)
                    {
                        <td class="text-center">
                            <a asp-action="Edit"
                               asp-route-id="@r.RoomNo"
                               class="btn btn-sm btn-info me-1">
                                Edit
                            </a>

                            <a asp-action="Delete"
                               asp-route-id="@r.RoomNo"
                               class="btn btn-sm btn-danger">
                                Delete
                            </a>
                        </td>
                    }
            </tr>
                        }
        </tbody>
    </table>

</div>