@model IReadOnlyList<HotelManagement.WebApp.Application.Dtos.Room.RoomDto>
@using HotelManagement.WebApp.Domain.Enums

@{
    ViewData["Title"] = "Rooms";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>Rooms</h3>
        <a asp-action="Create" class="btn btn-primary">Add Room</a>
    </div>

    <form method="get" class="row g-2 mb-3">
        <div class="col-md-4">
            <select name="type"
                    class="form-select"
                    asp-items="Html.GetEnumSelectList<RoomType>()">
                <option value="">All Room Types</option>
            </select>
        </div>
        <div class="col-md-2">
            <button class="btn btn-outline-secondary w-100">Filter</button>
        </div>
    </form>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-light">
            <tr>
                <th>Room No</th>
                <th>Type</th>
                <th>AC</th>
                <th>Status</th>
                <th>Clean</th>
                <th class="text-end">Price</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.RoomNo</td>
                    <td>@r.RoomType</td>
                    <td>@r.AcOption</td>
                    <td>
                        <span class="badge @(r.AvailabilityStatus.ToString() == "Available"
                                                      ? "bg-success" : "bg-danger")">
                        @r.AvailabilityStatus
                    </span>
                </td>
                <td>@r.CleanStatus</td>
                <td class="text-end">₹ @r.Price</td>
                <td class="text-center">
                    <a asp-action="Edit" asp-route-id="@r.RoomNo"
                       class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@r.RoomNo"
                       class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
                        }
        </tbody>
    </table>

</div>