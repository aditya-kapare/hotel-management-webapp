@model IReadOnlyList<HotelManagement.WebApp.Application.Dtos.Room.RoomDTO>

@{
    ViewData["Title"] = "Rooms";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between mb-3">
        <h4 class="fw-bold">Rooms</h4>

        <div>
            @if (ViewBag.IsReadOnly)
            {
                <a href="/reception/home" class="btn btn-dark mt-3">← Back</a>
            }
            else
            {
                <a href="/admin/home" class="btn btn-secondary mt-3">← Back</a>
                <a asp-action="Create" class="btn btn-primary mt-3">+ Add Room</a>
            }
        </div>
    </div>

    <!-- ✅ FILTERS -->
    <form method="get" class="row g-3 mb-4 align-items-end">

        <div class="col-md-3">
            <label class="form-label fw-semibold">Room Type</label>
            <select name="type" class="form-select">
                <option value="">All</option>
                @foreach (RoomType t in ViewBag.RoomTypes)
                {
                    <option value="@((int)t)"
                            selected="@(ViewBag.SelectedType != null && (int)t == ViewBag.SelectedType)">
                        @t.ToDisplayName()
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-semibold">AC Option</label>
            <select name="acOption" class="form-select">
                <option value="">All</option>
                @foreach (AcOption ac in ViewBag.AcOptions)
                {
                    <option value="@((int)ac)"
                            selected="@(ViewBag.SelectedAc != null && (int)ac == ViewBag.SelectedAc)">
                        @ac.ToDisplayName()
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-semibold">Clean Status</label>
            <select name="cleanStatus" class="form-select">
                <option value="">All</option>
                @foreach (CleanStatus cs in ViewBag.CleanStatuses)
                {
                    <option value="@((int)cs)"
                            selected="@(ViewBag.SelectedClean != null && (int)cs == ViewBag.SelectedClean)">
                        @cs.ToDisplayName()
                    </option>
                }
            </select>
        </div>

        <div class="col-md-3">
            <label class="form-label fw-semibold">Availability</label>
            <select name="availabilityStatus" class="form-select">
                <option value="">All</option>
                @foreach (AvailabilityStatus av in ViewBag.AvailabilityStatuses)
                {
                    <option value="@((int)av)"
                            selected="@(ViewBag.SelectedAvailability != null && (int)av == ViewBag.SelectedAvailability)">
                        @av.ToDisplayName()
                    </option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <button type="submit" class="btn btn-primary w-100">Filter</button>
        </div>

        <div class="col-md-1">
            <a href="@(ViewBag.IsReadOnly ? "/rooms" : "/admin/rooms")"
               class="btn btn-danger w-100">Reset</a>
        </div>
    </form>

    <!-- ✅ TABLE -->
    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Room No</th>
                <th>Type</th>
                <th>AC</th>
                <th>Availability</th>
                <th>Clean Status</th>
                <th class="text-end">Price</th>
                @if (!ViewBag.IsReadOnly)
                {
                    <th class="text-center">Action</th>
                }
            </tr>
        </thead>

        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.RoomNo</td>
                    <td>@(((RoomType)r.RoomType).ToDisplayName())</td>
                    <td>@(((AcOption)r.AcOption).ToDisplayName())</td>
                    <td>
                        <span class="badge @(((AvailabilityStatus)r.AvailabilityStatus == AvailabilityStatus.Available)
                                                          ? "bg-success" : "bg-danger")">
                        @(((AvailabilityStatus)r.AvailabilityStatus).ToDisplayName())
                    </span>
                </td>
                <td>@(((CleanStatus)r.CleanStatus).ToDisplayName())</td>
                <td class="text-end">₹ @r.Price</td>

                @if (!ViewBag.IsReadOnly)
                    {
                        <td class="text-center">
                            <a asp-action="Edit"
                               asp-route-id="@r.RoomNo"
                               class="btn btn-sm btn-info">Edit</a>

                            <a asp-action="Delete"
                               asp-route-id="@r.RoomNo"
                               class="btn btn-sm btn-danger ms-2">Delete</a>
                        </td>
                    }
                </tr>
            }
        </tbody>
    </table>

</div>