@model HotelManagement.WebApp.Application.Dtos.Drivers.CabDriverForCreationDTO
<!DOCTYPE html>
<html>
<head>
    <title>Add Cab Driver</title>

    <!-- ✅ Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container mt-5">

        <div class="col-md-2 ms-auto text-end">
            <a href="/admin/cabdrivers" class="btn btn-secondary">
                ← Back
            </a>
        </div>

        <div class="card shadow-sm">
            <div class="card-header bg-primary text-white">
                <h4 class="mb-0">Add Cab Driver</h4>
            </div>

            <div class="card-body">
                <form action="/admin/cabdrivers/create" method="post">

                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
                    <!-- ✅ Government ID -->
                    <div class="mb-3">
                        <label class="form-label">Government ID</label>
                        <input type="text"
                               asp-for="GovernmentId"
                               class="form-control"
                               placeholder="Aadhar / Driving License / Passport"
                               required
                               minlength="5"
                               maxlength="30" />

                        <span asp-validation-for="GovernmentId" class="text-danger"></span>
                    </div>

                    <!-- ✅ Name -->
                    <div class="mb-3">
                        <label class="form-label">Name</label>
                        <input type="text"
                               name="name"
                               class="form-control"
                               required
                               minlength="3"
                               maxlength="50" />
                    </div>

                    <!-- ✅ Age -->
                    <div class="mb-3">
                        <label class="form-label">Age</label>
                        <input type="number"
                               name="age"
                               class="form-control"
                               required
                               min="18"
                               max="65" />
                               title="Age must be above 18 and below 65" />
                    </div>

                    <!-- ✅ Gender -->
                    <div class="mb-3">
                        <label class="form-label">Gender</label>
                        <select name="gender" class="form-select" required>
                            <option value="">-- Select Gender --</option>
                            <option value="0">Male</option>
                            <option value="1">Female</option>
                        </select>
                    </div>

                    <!-- ✅ Car Vendor -->
                    <div class="mb-3">
                        <label class="form-label">Vendor</label>
                        <select name="carVendor" class="form-select" required>
                            <option value="">-- Select Vendor --</option>
                            <option value="Ola">Ola</option>
                            <option value="Uber">Uber</option>
                        </select>
                    </div>

                    <!-- ✅ Car Type -->
                    <div class="mb-3">
                        <label class="form-label">Car Type</label>
                        <select name="carType" class="form-select" required>
                            <option value="">-- Select Car Type --</option>
                            <option value="Sedan">Sedan</option>
                            <option value="SUV">SUV</option>
                        </select>
                    </div>

                    <!-- ✅ Actions -->
                    <div class="mt-3">
                        <button type="submit" class="btn btn-success">
                            Add Driver
                        </button>

                        <button type="button"
                                class="btn btn-secondary ms-2"
                                onclick="history.back()">
                            Cancel
                        </button>
                    </div>

                </form>
            </div>
        </div>
    </div>

</body>
</html>