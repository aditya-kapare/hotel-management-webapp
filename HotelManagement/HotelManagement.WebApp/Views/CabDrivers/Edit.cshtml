@model HotelManagement.WebApp.Application.Dtos.Drivers.CabDriverForUpdateDTO

<div class="container mt-4">

    <h4 class="fw-bold">Edit Cab Driver</h4>

    <div class="col-md-2 ms-auto text-end">
        <a href="/admin/cabdrivers" class="btn btn-secondary">
            ← Back
        </a>
    </div>

    <hr />

    <div class="card shadow">
        <div class="card-body">

            <form method="post">

                <div class="row g-3">

                    <!-- Government ID -->
                    <div class="col-md-6">
                        <label class="form-label">Government ID</label>
                        <input type="text"
                               name="GovernmentId"
                               class="form-control"
                               value="@Model.GovernmentId"
                               required
                               minlength="5"
                               maxlength="30" />
                    </div>

                    <!-- Name -->
                    <div class="col-md-6">
                        <label class="form-label">Name</label>
                        <input type="text"
                               name="Name"
                               class="form-control"
                               value="@Model.Name"
                               required
                               minlength="3"
                               maxlength="50" />
                    </div>

                    <!-- Age -->
                    <div class="col-md-3">
                        <label class="form-label">Age</label>
                        <input type="number"
                               name="Age"
                               class="form-control"
                               value="@Model.Age"
                               required
                               min="18"
                               max="65" />
                    </div>

                    <!-- Gender (KEEP YOUR ENUM LOGIC ✅) -->
                    <div class="col-md-3">
                        <label class="form-label">Gender</label>
                        <select name="Gender" class="form-select" required>
                            @foreach (var g in Enum.GetValues(typeof(Gender)))
                            {
                                <option value="@g"
                                        selected="@((Gender)Model.Gender == (Gender)g)">
                                    @g
                                </option>
                            }
                        </select>
                    </div>

                    <!-- Car Vendor (DROPDOWN ✅) -->
                    <div class="col-md-6">
                        <label class="form-label">Car Vendor</label>
                        <select name="CarVendor" class="form-select" required>
                            <option value="">-- Select Vendor --</option>
                            <option value="Ola" selected="@(Model.CarVendor == "Ola")">Ola</option>
                            <option value="Uber" selected="@(Model.CarVendor == "Uber")">Uber</option>
                        </select>
                    </div>

                    <!-- Car Type (DROPDOWN ✅) -->
                    <div class="col-md-6">
                        <label class="form-label">Car Type</label>
                        <select name="CarType" class="form-select" required>
                            <option value="">-- Select Car Type --</option>
                            <option value="Sedan" selected="@(Model.CarType == "Sedan")">Sedan</option>
                            <option value="SUV" selected="@(Model.CarType == "SUV")">SUV</option>
                        </select>
                    </div>

                </div>

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        Update
                    </button>

                    <a href="/admin/cabdrivers" class="btn btn-secondary">
                        Cancel
                    </a>
                </div>

            </form>

        </div>
    </div>
</div>