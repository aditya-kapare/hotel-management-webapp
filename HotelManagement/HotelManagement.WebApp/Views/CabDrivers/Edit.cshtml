@model HotelManagement.WebApp.Application.Dtos.Drivers.CabDriverRequest
@using HotelManagement.WebApp.Domain.Enums

@{
    ViewData["Title"] = "Edit Cab Driver";
}

<div class="container mt-5">
    <div class="card shadow-sm">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Edit Cab Driver</h4>

            <a href="/admin/cabdrivers" class="btn btn-outline-light btn-sm">
                ← Back
            </a>
        </div>

        <div class="card-body">
            <form method="post">

                <!-- Name -->
                <div class="mb-3">
                    <label class="form-label">Name</label>
                    <input type="text"
                           name="Name"
                           class="form-control"
                           value="@Model.Name"
                           required />
                </div>

                <!-- Age (HTML5 validation: 18+) -->
                <div class="mb-3">
                    <label class="form-label">Age</label>
                    <input type="number"
                           name="Age"
                           class="form-control"
                           value="@Model.Age"
                           required
                           min="18"
                           title="Age must be 18 or above" />
                </div>

                <!-- Gender (ENUM: Male, Female, Other) -->
                <div class="mb-3">
                    <label class="form-label">Gender</label>
                    <select name="Gender" class="form-select" required>
                        @foreach (Gender g in Enum.GetValues(typeof(Gender)))
                        {
                            <option value="@g" selected="@(Model.Gender == g)">
                                @g
                            </option>
                        }
                    </select>
                </div>

                <!-- Vendor (same as Create) -->
                <div class="mb-3">
                    <label class="form-label">Vendor</label>
                    <select name="CarVendor" class="form-select" required>
                        <option value="">-- Select Vendor --</option>
                        <option value="Ola" selected="@(Model.CarVendor == "Ola")">Ola</option>
                        <option value="Uber" selected="@(Model.CarVendor == "Uber")">Uber</option>
                    </select>
                </div>

                <!-- Car Type (same as Create) -->
                <div class="mb-3">
                    <label class="form-label">Car Type</label>
                    <select name="CarType" class="form-select" required>
                        <option value="">-- Select Car Type --</option>
                        <option value="Sedan" selected="@(Model.CarType == "Sedan")">Sedan</option>
                        <option value="SUV" selected="@(Model.CarType == "SUV")">SUV</option>
                    </select>
                </div>

                <!-- Submit -->
                <div class="mt-4 d-flex justify-content-end">
                    <button type="submit" class="btn btn-primary px-4">
                        Update Driver
                    </button>
                </div>

            </form>
        </div>
    </div>
</div>