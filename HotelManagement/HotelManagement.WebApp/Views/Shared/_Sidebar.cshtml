@using Microsoft.AspNetCore.Identity

<div id="sidebar"
     class="sidebar bg-dark text-white p-3"
     style="width:250px;
            margin-left:-250px;
            transition: margin-left 0.3s ease;">

    <ul class="nav flex-column gap-1">

        @* ================= ADMIN ================= *@
        @if (User.IsInRole("Admin"))
        {
            <li class="nav-item">
                <a href="/admin/employees" class="nav-link text-white">
                    <i class="bi bi-people-fill me-2"></i> Employees
                </a>
            </li>

            <li class="nav-item">
                <a href="/admin/rooms" class="nav-link text-white">
                    <i class="bi bi-door-closed-fill me-2"></i> Rooms
                </a>
            </li>

            <li class="nav-item">
                <a href="/admin/cabdrivers" class="nav-link text-white">
                    <i class="bi bi-car-front-fill me-2"></i> Cab Drivers
                </a>
            </li>
        }

        @* ================= RECEPTIONIST ================= *@
        @if (User.IsInRole("Receptionist"))
        {
            <li class="nav-item">
                <a href="/customers" class="nav-link text-white">
                    <i class="bi bi-people-fill me-2"></i> Customers
                </a>
            </li>

            <li class="nav-item">
                <a href="/rooms" class="nav-link text-white">
                    <i class="bi bi-door-closed-fill me-2"></i> Rooms
                </a>
            </li>

            <li class="nav-item">
                <a href="/stays" class="nav-link text-white">
                    <i class="bi bi-journal-check me-2"></i> Stays
                </a>
            </li>

            <li class="nav-item">
                <a href="/cabservice" class="nav-link text-white">
                    <i class="bi bi-car-front-fill me-2"></i> Drop & Pick
                </a>
            </li>
        }

    </ul>
</div>