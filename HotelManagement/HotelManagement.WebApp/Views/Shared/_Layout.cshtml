@using Microsoft.AspNetCore.Identity

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>@ViewData["Title"] - Hotel Management</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/css/bootstrap.min.css"
          rel="stylesheet" />

    <!-- ✅ Bootstrap Icons (CRITICAL – fixes disappearing icons) -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"
          rel="stylesheet" />

    <link href="~/css/site.css" rel="stylesheet" />

</head>

<body class="bg-light">

    <!-- TOP BAR -->
    @if (!(ViewData["HideSidebar"] as bool? ?? false))
    {
        ///////
        
        <nav class="navbar navbar-light bg-white shadow-sm px-4 d-flex justify-content-between">

            <!-- LEFT: Toggle + App name + username -->
            <div class="d-flex align-items-center gap-3">

                <!-- Sidebar Toggle -->
                <button id="sidebarToggle"
                        class="btn btn-outline-secondary btn-sm">
                    <i class="bi bi-list"></i>
                </button>

                <!-- App Name -->
                <span class="navbar-brand fw-bold mb-0">
                    Hotel Management
                </span>

                <!-- Username (START position ✅) -->
                @* @if (User.Identity?.IsAuthenticated ?? false)
                {
                    <span class="text-muted small">
                        | @User.Identity.Name
                        (
                        @(User.IsInRole("Admin")
                            ? "Admin"
                            : User.IsInRole("Receptionist")
                                ? "Receptionist"
                                : "User")
                        )
                    </span>
                } *@
            </div>

            <!-- RIGHT: Username + Logout -->
            <div class="d-flex align-items-center gap-3">

                @if(User.Identity != null && User.Identity.IsAuthenticated)
                {
                    <form method="post" action="/account/logout" class="d-flex align-items-center gap-2">
                        <span class="text-muted small">
                            @User.Identity.Name
                        </span>
                        <button type="submit" class="btn btn-outline-secondary btn-sm">
                            Logout
                        </button>
                    </form>
                }
            </div>

        </nav>


        ///////
    }

    <!-- PAGE CONTENT -->
    <div class="d-flex" style="min-height: calc(100vh - 56px);">

        <!-- SIDEBAR -->
        @if (
                User.Identity != null &&
                User.Identity.IsAuthenticated &&
                (User.IsInRole("Admin") || User.IsInRole("Receptionist")) &&
                !(ViewData["HideSidebar"] as bool? ?? false)
                )
        {
            <partial name="_Sidebar" />
        }

        <!-- MAIN CONTENT -->
        <main class="flex-grow-1 container my-4">
            @RenderBody()
        </main>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.1/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"></script>

    <!-- ✅ MVC Validation Scripts -->
    <script src="~/lib/jquery/jquery.min.js"></script>
    <script src="~/lib/jquery-validation/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    <!-- ✅ Sidebar Toggle Script -->
    <script>
        document.addEventListener("DOMContentLoaded", function () {

            const toggleBtn = document.getElementById("sidebarToggle");
            const sidebar = document.getElementById("sidebar");

            // If sidebar or button doesn't exist (login page), stop here
            if (!toggleBtn || !sidebar) return;

            // ✅ default CLOSED
            if (localStorage.getItem("sidebarOpen") === null) {
                localStorage.setItem("sidebarOpen", "false");
            }

            function applyState() {
                const isOpen = localStorage.getItem("sidebarOpen") === "true";
                sidebar.style.marginLeft = isOpen ? "0px" : "-250px";
            }

            // Apply sidebar state on every page load
            applyState();

            // Toggle on button click
            toggleBtn.addEventListener("click", function () {
                const isOpen = localStorage.getItem("sidebarOpen") === "true";
                localStorage.setItem("sidebarOpen", (!isOpen).toString());
                applyState();
            });
        });
    </script>
    

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>