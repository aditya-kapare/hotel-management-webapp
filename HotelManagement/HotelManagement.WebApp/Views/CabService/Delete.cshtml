@model HotelManagement.WebApp.Application.Dtos.DropPickRequests.DropPickRequestDto

@{
    ViewData["Title"] = "Delete Cab Request";
}

<div class="container mt-4">

    <h3 class="text-danger fw-bold mb-3">
        Delete Cab Request
    </h3>

    <div class="card shadow-sm border-danger">
        <div class="card-body">

            <p class="mb-4">
                Are you sure you want to delete this drop / pick request?
            </p>

            <ul class="list-group mb-4">
                <li class="list-group-item">
                    <strong>Request ID:</strong> @Model.RequestId
                </li>
                <li class="list-group-item">
                    <strong>Stay ID:</strong> @Model.StayId
                </li>
                <li class="list-group-item">
                    <strong>Driver ID:</strong> @Model.DriverId
                </li>
                <li class="list-group-item">
                    <strong>Type:</strong> @Model.RequestType
                </li>
                <li class="list-group-item">
                    <strong>Requested At:</strong> @Model.RequestedAt
                </li>
            </ul>

            <form method="post" class="d-flex gap-2">
                @Html.AntiForgeryToken()

                <button type="submit" class="btn btn-danger">
                    Yes, Delete
                </button>

                /cabservice
                Cancel
                </a>
            </form>

        </div>
    </div>

</div>
