@model IReadOnlyList<HotelManagement.WebApp.Application.Dtos.DropPickRequests.DropPickRequestDto>

@{
    ViewData["Title"] = "Cab Service";
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
<div class="container mt-4">

    @* ✅ SUCCESS MESSAGE AFTER ASSIGN *@
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="fw-bold">Cab Service Requests</h3>

        <a asp-controller="CabService"
           asp-action="Create"
           class="btn btn-primary">
            + Create New Request
        </a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Request ID</th>
                <th>Stay ID</th>
                <th>Driver ID</th>
                <th>Request Type</th>
                <th>Requested At</th>
                <th style="width:180px">Actions</th>
            </tr>
        </thead>

        <tbody>
            @if (Model != null && Model.Count > 0)
            {
                foreach (var r in Model)
                {
                    <tr>
                        <td>@r.RequestId</td>
                        <td>@r.StayId</td>
                        <td>@r.DriverId</td>
                        <td>@r.RequestType</td>
                        <td>@r.RequestedAt</td>
                        <td>
                            <a asp-controller="CabService"
                               asp-action="Edit"
                               asp-route-id="@r.RequestId"
                               class="btn btn-sm btn-warning">
                                Edit
                            </a>

                            <a asp-controller="CabService"
                               asp-action="Delete"
                               asp-route-id="@r.RequestId"
                               class="btn btn-sm btn-danger ms-2">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="6" class="text-center text-muted">
                        No cab service requests found.
                    </td>
                </tr>
            }
        </tbody>
    </table>

    <a href="/reception/home" class="btn btn-secondary mt-3">
        ← Back
    </a>

</div>