@model HotelManagement.WebApp.Application.Dtos.DropPickRequests.UpdateDropPickRequest

<h3>Edit Cab Request</h3>

<form method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label>Request Type</label>
        <select asp-for="RequestType" class="form-select">
            <option value="Drop">Drop</option>
            <option value="Pick">Pick</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Driver</label>
        <select asp-for="DriverId" class="form-select">
            @foreach (var d in ViewBag.Drivers)
            {
                <option value="@d.DriverId">@d.Name</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Requested At</label>
        <input asp-for="RequestedAt" type="datetime-local" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Notes</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>

    <button class="btn btn-primary">Update</button>
    <a href="/cabservice" class="btn btn-secondary ms-2">Cancel</a>
</form>