@model HotelManagement.WebApp.Application.Dtos.DropPickRequests.CreateDropPickRequest
@using HotelManagement.WebApp.Domain.Enums

<h3>Customer Drop & Pick Service</h3>

<form method="post">
    @Html.AntiForgeryToken()

    <div class="mb-3">
        <label>Active Stay</label>
        <select asp-for="StayId" class="form-select">
            @foreach (var s in ViewBag.Stays)
            {
                <option value="@s.StayId">
                    Stay @s.StayId (Room @s.RoomNo)
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Request Type</label>
        <select asp-for="RequestType" class="form-select">
            <option value="Drop">Drop</option>
            <option value="Pick">Pick</option>
        </select>
    </div>

    <div class="mb-3">
        <label>Pickup / Drop Time</label>
        <select asp-for="RequestedAt" class="form-select">
            @for (int h = 0; h < 24; h++)
            {
                var t = DateTime.Today.AddHours(h);
                <option value="@t">@t.ToString("HH:mm")</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Select Driver</label>
        <select asp-for="DriverId" class="form-select">
            @foreach (var d in ViewBag.Drivers)
            {
                <option value="@d.DriverId">
                    @d.Name (@d.CarVendor)
                </option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label>Notes</label>
        <textarea asp-for="Notes" class="form-control"></textarea>
    </div>

    <button class="btn btn-success">Assign Driver</button>
    <a href="/cabservice" class="btn btn-secondary ms-2">Cancel</a>
</form>

@if (!ViewData.ModelState.IsValid)
{
    <div class="alert alert-danger mt-3">
        @foreach (var e in ViewData.ModelState.Values.SelectMany(v => v.Errors))
        {
            <div>@e.ErrorMessage</div>
        }
    </div>
}