@model HotelManagement.WebApp.ViewModels.Customers.CreateCustomerViewModel

<h3 class="mb-4">Add New Customer</h3>

<form method="post" class="row g-3">

    <div class="col-md-6">
        <label asp-for="IdentityIdType" class="form-label"></label>
        <select asp-for="IdentityIdType" class="form-select"
                asp-items="Html.GetEnumSelectList<HotelManagement.WebApp.Domain.Enums.IdentityIdType>()">
            <option value="">-- Select --</option>
        </select>
    </div>

    <div class="col-md-6">
        <label asp-for="IdentityId" class="form-label"></label>
        <input asp-for="IdentityId" class="form-control" />
    </div>

    <div class="col-md-6">
        <label asp-for="Name" class="form-label"></label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="col-md-6">
        <label asp-for="MobileNo" class="form-label"></label>
        <input asp-for="MobileNo" class="form-control" />
    </div>

    <div class="col-md-6">
        <label asp-for="Gender" class="form-label"></label>
        <select asp-for="Gender" class="form-select"
                asp-items="Html.GetEnumSelectList<HotelManagement.WebApp.Domain.Enums.Gender>()">
            <option value="">-- Select --</option>
        </select>
    </div>

    <div class="col-md-6">
        <label asp-for="Country" class="form-label"></label>
        <input asp-for="Country" class="form-control" />
    </div>

    <div class="col-12">
        <label asp-for="Address" class="form-label"></label>
        <textarea asp-for="Address" class="form-control"></textarea>
    </div>

    <div class="col-12">
        <button type="submit" class="btn btn-primary">
            Save Customer
        </button>
        <a href="/customers" class="btn btn-secondary ms-2">
            Back
        </a>
    </div>

</form>