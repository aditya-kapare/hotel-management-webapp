@using HotelManagement.WebApp.ViewModels.DropPickRequests
@using HotelManagement.WebApp.Domain.Enums
@model IReadOnlyList<DropPickRequestViewListModel>

@{
    ViewData["Title"] = "Drop / Pick Requests";
}

<div class="container mt-4">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold">Drop / Pick Requests</h4>

        <a asp-controller="DropPickRequests"
           asp-action="Create"
           class="btn btn-primary btn-sm">
            + Create New Request
        </a>
    </div>

    <table class="table table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>Request ID</th>
                <th>Room No</th>
                <th>Customer Name</th>
                <th>Customer No</th>
                <th>Cab Driver</th>
                <th>Status</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var r in Model)
            {
                <tr>
                    <td>@r.RequestId</td>
                    <td>@r.RoomNo</td>
                    <td>@r.CustomerName</td>
                    <td>@r.CustomerMobileNo</td>

                    <td>
                        @if (!string.IsNullOrWhiteSpace(r.DriverName) &&
                                            !r.DriverName.Equals("Unassigned", StringComparison.OrdinalIgnoreCase))
                        {
                            @r.DriverName
                        }
                        else
                        {
                            <span class="text-muted">Not Assigned</span>
                        }
                    </td>

                    <!-- STATUS -->
                    <td>
                        @switch (r.Status)
                        {
                            case DropPickStatus.Assigned:
                                <span class="badge bg-secondary">Assigned</span>
                                break;
                            case DropPickStatus.InProgress:
                                <span class="badge bg-info text-dark">In Progress</span>
                                break;
                            case DropPickStatus.Completed:
                                <span class="badge bg-success">Completed</span>
                                break;
                            case DropPickStatus.Cancelled:
                                <span class="badge bg-danger">Cancelled</span>
                                break;
                        }
                    </td>

                    <!-- ACTIONS -->
                    <td class="text-center">
                        <!-- VIEW -->
                        <a asp-action="Details"
                           asp-route-id="@r.RequestId"
                           class="btn btn-sm btn-secondary me-1">
                            View
                        </a>

                        @if (r.CanEdit)
                        {
                            <!-- EDIT -->
                            <a asp-action="Edit"
                               asp-route-id="@r.RequestId"
                               class="btn btn-sm btn-info me-1">
                                Edit
                            </a>

                            <!-- CANCEL (SOFT DELETE) -->
                            <form asp-action="Delete"
                                  asp-route-id="@r.RequestId"
                                  method="post"
                                  class="d-inline"
                                  onsubmit="return confirm('Cancel this request?');">
                                @Html.AntiForgeryToken()
                                <button type="submit"
                                        class="btn btn-sm btn-warning">
                                    Cancel
                                </button>
                            </form>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success mt-3">
            @TempData["Success"]
        </div>
    }

    <a href="/reception/home" class="btn btn-secondary mt-3">
        ← Back
    </a>
</div>