@model HotelManagement.WebApp.ViewModels.DropPickRequests.DropPickRequestViewListModel

@{
    ViewData["Title"] = "Drop / Pick Details";
}

<div class="container mt-4">

    <h4 class="fw-bold mb-3">Request Details</h4>

    <div class="card shadow-sm">
        <div class="card-body">

            <div class="row mb-2">
                <div class="col-sm-4 fw-bold">Request ID</div>
                <div class="col-sm-8">@Model.RequestId</div>
            </div>

            <div class="row mb-2">
                <div class="col-sm-4 fw-bold">Room No</div>
                <div class="col-sm-8">@Model.RoomNo</div>
            </div>

            <hr />

            <div class="row mb-2">
                <div class="col-sm-4 fw-bold">Customer Name</div>
                <div class="col-sm-8">@Model.CustomerName</div>
            </div>

            <div class="row mb-2">
                <div class="col-sm-4 fw-bold">Customer Phone</div>
                <div class="col-sm-8">@Model.CustomerMobileNo</div>
            </div>

            <hr />

            <div class="row mb-2">
                <div class="col-sm-4 fw-bold">Driver Name</div>
                <div class="col-sm-8">
                    @if (!string.IsNullOrWhiteSpace(Model.DriverName) &&
                                        !Model.DriverName.Equals("Unassigned", StringComparison.OrdinalIgnoreCase))
                    {
                        @Model.DriverName
                    }
                    else
                    {
                        <span class="text-muted">Not Assigned</span>
                    }
                </div>
            </div>

            <hr />

            <div class="row mb-2">
                <div class="col-sm-4 fw-bold">Request Type</div>
                <div class="col-sm-8">@Model.RequestType</div>
            </div>

            <div class="row mb-2">
                <div class="col-sm-4 fw-bold">Requested At</div>
                <div class="col-sm-8">@Model.RequestedAt</div>
            </div>

            @if (!string.IsNullOrWhiteSpace(Model.Notes))
            {
                <hr />
                <div class="row mb-2">
                    <div class="col-sm-4 fw-bold">Notes</div>
                    <div class="col-sm-8">@Model.Notes</div>
                </div>
            }

        </div>
    </div>

    <div class="mt-3">
        <a asp-action="Index" class="btn btn-secondary">
            ← Back
        </a>

        @if (Model.CanEdit)
        {
            <a asp-action="Edit"
               asp-route-id="@Model.RequestId"
               class="btn btn-info ms-2">
                Edit
            </a>
        }
    </div>

</div>