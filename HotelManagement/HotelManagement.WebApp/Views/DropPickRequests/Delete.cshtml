@using HotelManagement.WebApp.ViewModels.DropPickRequests
@model DeleteDropPickRequestViewModel

@{
    ViewData["Title"] = "Delete Drop / Pick Request";
}

<div class="container mt-4">

    <h4 class="text-danger fw-bold mb-3">
        Delete Drop / Pick Request
    </h4>

    <div class="card border-danger shadow-sm">
        <div class="card-body">

            <p>Are you sure you want to delete this request?</p>

            <ul class="list-group mb-3">
                <li class="list-group-item">
                    <strong>Request ID:</strong> @Model.RequestId
                </li>
                <li class="list-group-item">
                    <strong>Room No:</strong> @Model.RoomNo
                </li>
                <li class="list-group-item">
                    <strong>Customer:</strong> @Model.CustomerName
                </li>
                <li class="list-group-item">
                    <strong>Driver:</strong> @Model.DriverName
                </li>
                <li class="list-group-item">
                    <strong>Type:</strong> @Model.RequestType
                </li>
            </ul>

            <form asp-action="Delete"
                  asp-route-id="@Model.RequestId"
                  method="post"
                  class="d-flex gap-2">
                @Html.AntiForgeryToken()

                <button type="submit" class="btn btn-danger">
                    Yes, Delete
                </button>

                <a asp-action="Index"
                   class="btn btn-secondary">
                    Cancel
                </a>
            </form>

        </div>
    </div>
</div>